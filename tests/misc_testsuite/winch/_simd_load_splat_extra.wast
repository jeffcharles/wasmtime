(module
  (memory 1)
  (data (i32.const 0) "\02")
  (func (export "8") (result v128)
    (v128.load8_splat (i32.const 0))
  )
  (func (export "16") (result v128)
    (v128.load16_splat (i32.const 0))
  )
  (func (export "32") (result v128)
    (v128.load32_splat (i32.const 0))
  )
  (func (export "64") (result v128)
    (v128.load64_splat (i32.const 0))
  )
)

(assert_return (invoke "8") (v128.const i16x8 0x0202 0x0202 0x0202 0x0202 0x0202 0x0202 0x0202 0x0202))
(assert_return (invoke "16") (v128.const i16x8 2 2 2 2 2 2 2 2))
(assert_return (invoke "32") (v128.const i32x4 2 2 2 2))
(assert_return (invoke "64") (v128.const i64x2 2 2))